  "faqs": [
    {
      "id": 1,
      "question": "چگونه بلیط هواپیما بخریم؟",
      "answer": "مبدا، مقصد، تاریخ و تعداد مسافر را وارد کنید و پرواز مورد نظر را انتخاب کنید. سپس اطلاعات مسافران را تکمیل کرده و با درگاه بانک پرداخت را انجام دهید."
    },
    {
      "id": 2,
      "question": "آیا امکان استرداد بلیط وجود دارد؟",
      "answer": "بله، طبق قوانین ایرلاین امکان استرداد وجود دارد. میزان جریمه کنسلی به زمان درخواست و نوع بلیط بستگی دارد."
    },
    {
      "id": 3,
      "question": "چند ساعت قبل از پرواز باید در فرودگاه باشیم؟",
      "answer": "برای پروازهای داخلی حداقل ۲ ساعت و برای پروازهای بین‌المللی حداقل ۳ ساعت قبل از پرواز در فرودگاه حضور داشته باشید."
    },
    {
      "id": 4,
      "question": "آیا کودکان هم نیاز به بلیط دارند؟",
      "answer": "بله، برای کودکان بالای ۲ سال بلیط با ۵۰٪ تخفیف و برای نوزادان زیر ۲ سال بلیط با ۱۰٪ قیمت بزرگسال صادر می‌شود."
    },
    {
      "id": 5,
      "question": "مدارک مورد نیاز برای سفر چیست؟",
      "answer": "برای سفرهای داخلی: کارت ملی یا شناسنامه. برای سفرهای خارجی: گذرنامه با حداقل ۶ ماه اعتبار و ویزای معتبر کشور مقصد."
    },
    {
      "id": 6,
      "question": "آیا می‌توانم صندلی مورد نظرم را انتخاب کنم؟",
      "answer": "بله، در مرحله انتخاب پرواز می‌توانید صندلی مورد نظر خود را از نقشه هواپیما انتخاب کنید."
    },
    {
      "id": 7,
      "question": "بار مجاز چقدر است؟",
      "answer": "بار مجاز در پروازهای داخلی ۲۰ کیلوگرم و در پروازهای خارجی ۲۳ تا ۳۰ کیلوگرم بستگی به کلاس پروازی دارد."
    },
    {
      "id": 8,
      "question": "آیا می‌توانم بلیط را به نام دیگری کنسل کنم؟",
      "answer": "خیر، بلیط فقط توسط شخص خریدار یا مسافر اصلی قابل استرداد است و تغییر نام پس از صدور بلیط امکان‌پذیر نیست."
    },
    {
      "id": 9,
      "question": "چگونه بلیط چارتر را از سیستمی تشخیص دهم؟",
      "answer": "بلیط چارتر معمولاً قیمت کمتری دارد اما شرایط کنسلی سخت‌تری دارد. بلیط سیستمی قیمت بالاتر اما انعطاف بیشتری دارد."
    }
  ]
